{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_POSTGRESQL", "label": "PostgreSQL WCIC", "type": "datasource", "pluginId": "postgres" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" }
  ],
  "title": "WCIC - News Intelligence & Sentiment",
  "uid": "wcic-news-intelligence",
  "description": "Sprint 4 - Monitoramento de coleta de notícias, análise GPT e sentimento por seleção",
  "tags": ["wcic", "sprint-4", "news", "sentiment", "gpt"],
  "timezone": "America/Sao_Paulo",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "schemaVersion": 38,
  "version": 1,
  "panels": [

    {
      "id": 1,
      "title": "Artigos coletados (últimas 24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value_and_name" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color": "red","value": 0},{"color":"yellow","value":5},{"color":"green","value":20}] }
        }
      },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value, 'Artigos' AS metric FROM wcic.news WHERE created_at > NOW() - INTERVAL '24 hours'",
        "format": "table"
      }]
    },

    {
      "id": 2,
      "title": "Artigos analisados pelo GPT (últimas 24h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"red","value":0},{"color":"yellow","value":3},{"color":"green","value":10}] }
        }
      },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value FROM wcic.news_analysis na JOIN wcic.news n ON n.id=na.news_id WHERE n.created_at > NOW() - INTERVAL '24 hours'",
        "format": "table"
      }]
    },

    {
      "id": 3,
      "title": "Artigos de alto impacto (score ≥ 0.7)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"green","value":0},{"color":"orange","value":3},{"color":"red","value":8}] },
          "unit": "short"
        }
      },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value FROM wcic.news_analysis WHERE impact_score >= 0.7 AND created_at > NOW() - INTERVAL '24 hours'",
        "format": "table"
      }]
    },

    {
      "id": 4,
      "title": "Taxa de processamento GPT",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizValue": 0, "maxVizValue": 100 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "steps": [{"color":"red","value":0},{"color":"yellow","value":60},{"color":"green","value":85}] }
        }
      },
      "targets": [{
        "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN processing_status='processed' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 1) AS value FROM wcic.news WHERE created_at > NOW() - INTERVAL '24 hours'",
        "format": "table"
      }]
    },

    {
      "id": 5,
      "title": "Backlog de análise GPT (wcic:queue:news_analysis)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":10},{"color":"red","value":50}] }
        }
      },
      "targets": [{
        "expr": "wcic_redis_list_length{key=\"wcic:queue:news_analysis\"}",
        "legendFormat": "Backlog"
      }]
    },

    {
      "id": 6,
      "title": "Snapshots de sentimento (últimas 24h)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"red","value":0},{"color":"yellow","value":5},{"color":"green","value":20}] }
        }
      },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value FROM wcic.sentiment_snapshots WHERE captured_at > NOW() - INTERVAL '24 hours'",
        "format": "table"
      }]
    },

    {
      "id": 10,
      "title": "Volume de artigos coletados por hora",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1 hour', created_at) AS time, source, COUNT(*) AS value FROM wcic.news WHERE created_at > NOW() - INTERVAL '24 hours' GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 11,
      "title": "Distribuição de impact_score",
      "type": "histogram",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "targets": [{
        "rawSql": "SELECT ROUND(impact_score::numeric, 1) AS impact_range, COUNT(*) AS count FROM wcic.news_analysis WHERE created_at > NOW() - INTERVAL '24 hours' GROUP BY 1 ORDER BY 1",
        "format": "table"
      }],
      "options": { "bucketSize": "auto", "fillOpacity": 80 }
    },

    {
      "id": 20,
      "title": "Artigos por tipo de impacto (últimas 24h)",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"] },
      "targets": [{
        "rawSql": "SELECT impact_type AS metric, COUNT(*) AS value FROM wcic.news_analysis WHERE created_at > NOW() - INTERVAL '24 hours' GROUP BY impact_type ORDER BY value DESC",
        "format": "table"
      }]
    },

    {
      "id": 21,
      "title": "Sentimento das notícias (últimas 24h)",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "pieType": "pie", "displayLabels": ["name", "percent"] },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "positive" }, "properties": [{"id":"color","value":{"fixedColor":"green","mode":"fixed"}}] },
          { "matcher": { "id": "byName", "options": "very_positive" }, "properties": [{"id":"color","value":{"fixedColor":"dark-green","mode":"fixed"}}] },
          { "matcher": { "id": "byName", "options": "negative" }, "properties": [{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}] },
          { "matcher": { "id": "byName", "options": "very_negative" }, "properties": [{"id":"color","value":{"fixedColor":"dark-red","mode":"fixed"}}] },
          { "matcher": { "id": "byName", "options": "neutral" }, "properties": [{"id":"color","value":{"fixedColor":"gray","mode":"fixed"}}] }
        ]
      },
      "targets": [{
        "rawSql": "SELECT sentiment AS metric, COUNT(*) AS value FROM wcic.news_analysis WHERE created_at > NOW() - INTERVAL '24 hours' GROUP BY sentiment",
        "format": "table"
      }]
    },

    {
      "id": 22,
      "title": "Tokens OpenAI consumidos por hora",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      },
      "targets": [{
        "rawSql": "SELECT time_bucket('1 hour', created_at) AS time, SUM(tokens_used) AS \"Tokens\" FROM wcic.news_analysis WHERE created_at > NOW() - INTERVAL '24 hours' GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }]
    },

    {
      "id": 30,
      "title": "Sentimento por seleção (últimas 6h)",
      "type": "table",
      "gridPos": { "x": 0, "y": 20, "w": 16, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": {
        "sortBy": [{ "displayName": "Negativo", "desc": true }],
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Positivo" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "unit", "value": "percentunit" },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Negativo" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "unit", "value": "percentunit" },
              { "id": "thresholds", "value": { "steps": [{"color":"green","value":0},{"color":"yellow","value":0.3},{"color":"red","value":0.6}] } }
            ]
          }
        ]
      },
      "targets": [{
        "rawSql": "SELECT t.name AS \"Seleção\", t.short_name AS \"Código\", ROUND(AVG(ss.positive_ratio)::numeric,3) AS \"Positivo\", ROUND(AVG(ss.negative_ratio)::numeric,3) AS \"Negativo\", ROUND(AVG(ss.neutral_ratio)::numeric,3) AS \"Neutro\", ss.dominant_sentiment AS \"Sentimento\", MAX(ss.captured_at) AS \"Último snapshot\" FROM wcic.sentiment_snapshots ss JOIN wcic.teams t ON t.id = ss.entity_id WHERE ss.entity_type = 'team' AND ss.captured_at > NOW() - INTERVAL '6 hours' GROUP BY t.name, t.short_name, ss.dominant_sentiment ORDER BY \"Negativo\" DESC",
        "format": "table"
      }]
    },

    {
      "id": 31,
      "title": "Tendência de sentimento - últimas 24h",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "min": 0, "max": 1, "unit": "percentunit"
        }
      },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1 hour', captured_at) AS time, 'Positivo' AS metric, AVG(positive_ratio) AS value FROM wcic.sentiment_snapshots WHERE captured_at > NOW() - INTERVAL '24 hours' AND entity_type='team' GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT time_bucket('1 hour', captured_at) AS time, 'Negativo' AS metric, AVG(negative_ratio) AS value FROM wcic.sentiment_snapshots WHERE captured_at > NOW() - INTERVAL '24 hours' AND entity_type='team' GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 40,
      "title": "Execuções WF-03 e WF-04 (últimas 24h)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 1, "fillOpacity": 10 } }
      },
      "targets": [{
        "rawSql": "SELECT time_bucket('30 minutes', started_at) AS time, workflow_name AS metric, COUNT(*) AS value FROM wcic.workflow_logs WHERE workflow_name IN ('WF-03-news-intelligence','WF-04-sentiment-analyzer') AND started_at > NOW() - INTERVAL '24 hours' GROUP BY 1, 2 ORDER BY 1",
        "format": "time_series"
      }]
    },

    {
      "id": 41,
      "title": "Erros de workflow por tipo",
      "type": "table",
      "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "sortBy": [{ "displayName": "count", "desc": true }] },
      "targets": [{
        "rawSql": "SELECT workflow_name AS \"Workflow\", error_message AS \"Erro\", COUNT(*) AS \"Ocorrências\", MAX(started_at) AS \"Último\" FROM wcic.workflow_logs WHERE status='error' AND started_at > NOW() - INTERVAL '24 hours' GROUP BY workflow_name, error_message ORDER BY \"Ocorrências\" DESC LIMIT 20",
        "format": "table"
      }]
    }

  ]
}
JSONEOF
python3 -c "import json; d=json.load(open('/home/claude/wcic/dashboards/grafana/news-intelligence.json')); print(f'Dashboard: {len(d[\"panels\"])} panels - JSON válido')"
