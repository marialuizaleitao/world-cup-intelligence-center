      ]
    },
    "Call Sentiment Analyst": { "main": [[{ "node": "Increment Rate Limit", "type": "main", "index": 0 }]] },
    "Increment Rate Limit": { "main": [[{ "node": "Set RL TTL", "type": "main", "index": 0 }]] },
    "Set RL TTL": { "main": [[{ "node": "Check Sentiment Result", "type": "main", "index": 0 }]] },
    "Check Sentiment Result": { "main": [[{ "node": "Persist Sentiment Snapshot", "type": "main", "index": 0 }]] },
    "Persist Sentiment Snapshot": { "main": [[{ "node": "Cache Sentiment (30min)", "type": "main", "index": 0 }]] },
    "Cache Sentiment (30min)": { "main": [[{ "node": "Detect Sentiment Shift", "type": "main", "index": 0 }]] },
    "Detect Sentiment Shift": { "main": [[{ "node": "Alert Shift?", "type": "main", "index": 0 }]] },
    "Alert Shift?": {
      "main": [
        [{ "node": "Alert via WF-07", "type": "main", "index": 0 }],
        [{ "node": "Log Success", "type": "main", "index": 0 }]
      ]
    },
    "Alert via WF-07": { "main": [[{ "node": "Log Success", "type": "main", "index": 0 }]] }
  },
