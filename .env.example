# =============================================================================
# WCIC — World Cup Intelligence Center
# .env.example —> copie para .env e preencha todos os valores
#
# Geração de segredos:
#   openssl rand -hex 32   → para chaves de 64 chars
#   openssl rand -hex 24   → para senhas de 48 chars
# =============================================================================

# =============================================================================
# AMBIENTE
# =============================================================================

# development | staging | production
NODE_ENV=development

# =============================================================================
# POSTGRESQL — superuser
# Usado pelo container postgres e pelo postgres-exporter
# =============================================================================

# Senha do superuser "postgres" (criado automaticamente pela imagem)
POSTGRES_ROOT_PASSWORD=

# =============================================================================
# POSTGRESQL —> usuários de aplicação
# Cada serviço usa o seu próprio usuário com privilégios mínimos.
# Criados pelo script scripts/setup-database.sh via docker/postgres/init.sql
# =============================================================================

# Senha do usuário n8n_app (database: n8n)
# Usado por: serviços n8n, n8n-worker-1, n8n-worker-2
POSTGRES_N8N_PASSWORD=

# Senha do usuário wcic_app (database: wcic)
# Usado por: serviço api
# O n8n acessa o banco wcic via credencial configurada no próprio n8n (não via compose)
POSTGRES_WCIC_PASSWORD=

# Senha do usuário metabase_app (database: metabase)
# Usado por: serviço metabase
POSTGRES_METABASE_PASSWORD=

# Senha do usuário grafana_app (database: grafana)
# Usado por: serviço grafana
POSTGRES_GRAFANA_PASSWORD=

# =============================================================================
# REDIS
# Usado por: redis, n8n, n8n-worker-1, n8n-worker-2, api, redis-exporter
# =============================================================================

# Senha de autenticação do Redis (requirepass)
REDIS_PASSWORD=

# =============================================================================
# N8N —> autenticação e segurança
# =============================================================================

# Chave de criptografia para credenciais armazenadas no n8n
# CRITICAL: se perdida, todas as credenciais ficam inacessíveis
# Gere com: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Usuário e senha para acesso à UI e API do n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# URL base pública do n8n (usada para montar URLs de webhook)
# Desenvolvimento: http://localhost:5678/
# Produção: https://n8n.seudominio.com/
WEBHOOK_URL=http://localhost:5678/

# =============================================================================
# API REST PRÓPRIA —> services/api
# =============================================================================

# Porta interna do serviço Express
API_PORT=8080

# Segredo para assinar tokens JWT (autenticação de usuários da API)
# Gere com: openssl rand -hex 64
API_JWT_SECRET=

# Segredo para validar assinatura HMAC de webhooks recebidos
# Gere com: openssl rand -hex 32
API_WEBHOOK_SECRET=

# Rate limiting: janela em milissegundos e máximo de requisições por janela
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=100

# =============================================================================
# OBSERVABILIDADE
# =============================================================================

# Senha do admin do Grafana
GRAFANA_ADMIN_PASSWORD=

# =============================================================================
# OPENAI
# Usado pelos agentes de IA nos workflows n8n
# Configurado como credencial dentro do n8n, NÃO injetado via compose
# Mas documentado aqui para referência durante onboarding
# =============================================================================

# Chave da API OpenAI (começa com sk-)
OPENAI_API_KEY=

# ID da organização (opcional, necessário apenas em contas multi-org)
OPENAI_ORG_ID=

# Modelo padrão para todos os agentes
OPENAI_MODEL=gpt-4o

# Limite diário de gasto em USD (controle de custo)
OPENAI_DAILY_BUDGET_USD=20

# =============================================================================
# APIs ESPORTIVAS —> dados de futebol
# Configuradas como credenciais dentro do n8n
# =============================================================================

# Football-Data.org — API primária de dados de partidas
# Plano gratuito: 10 req/min, 100 req/dia
# https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# RapidAPI — API-Football (fallback quando Football-Data falha)
# https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=
RAPIDAPI_HOST=api-football-v1.p.rapidapi.com

# =============================================================================
# APIs DE NOTÍCIAS E MÍDIAS SOCIAIS
# Configuradas como credenciais dentro do n8n
# =============================================================================

# NewsAPI — artigos de notícias
# Plano gratuito: 100 req/dia
# https://newsapi.org/register
NEWSAPI_KEY=

# Twitter API v2 — Bearer Token para busca de tweets (read-only)
# https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=

# Reddit API — para monitoramento de subreddits
# https://www.reddit.com/prefs/apps (criar app do tipo "script")
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Conta de bot (necessária para OAuth2 via password flow)
REDDIT_USERNAME=
REDDIT_PASSWORD=

# =============================================================================
# NOTIFICAÇÕES DE SAÍDA
# Configuradas como credenciais dentro do n8n
# =============================================================================

# Telegram — bot para alertas operacionais e notificações ao usuário final
# Criar via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=

# IDs dos chats/canais de destino por categoria
# Obter via: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_ALERTS_CHAT_ID=     # Canal: #wcic-ops (alertas operacionais P1/P2)
TELEGRAM_NEWS_CHAT_ID=       # Canal: #wcic-news (notícias de alto impacto)
TELEGRAM_PREDICTIONS_CHAT_ID= # Canal: #wcic-predictions (previsões pré-jogo)
TELEGRAM_LIVE_CHAT_ID=       # Canal: #wcic-live (gols e eventos ao vivo)

# Slack —> notificações
# Criar Incoming Webhook em: https://api.slack.com/apps
SLACK_WEBHOOK_URL=
SLACK_OPS_CHANNEL=#wcic-ops
SLACK_ALERTS_CHANNEL=#wcic-alerts

# SendGrid —> envio de emails (digest diário, relatórios)
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@wcic.example.com
SENDGRID_FROM_NAME=WCIC Platform
